# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Inside Docker Compose use the service name (postgres) as HOST
DATABASE_URL=postgresql://spektr:spektr@postgres:5432/spektr

# Redis connection string
# Format: redis://HOST:PORT
# Inside Docker Compose use the service name (redis) as HOST
REDIS_URL=redis://redis:6379

# Supabase connection strings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_BUCKET=your-supabase-bucket

# Gemini API key
GEMINI_API_KEY=your-gemini-api-key-from-aistudio-google-com